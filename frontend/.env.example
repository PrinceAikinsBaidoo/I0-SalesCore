# Vite: variables must be prefixed with VITE_ to be exposed to the client.

# Default in code: /api/v1 (works with Vite dev proxy and docker nginx /api proxy).
# For a separate API host (e.g. https://api.example.com), set:
# VITE_API_BASE_URL=https://api.example.com/api/v1

# VITE_API_BASE_URL=/api/v1

# Paystack public key (get from https://dashboard.paystack.com/#/settings/developer)
# VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Fallback email used when customer email is missing/invalid during Paystack checkout.
# VITE_PAYSTACK_FALLBACK_EMAIL=payments@iosalescore.com
