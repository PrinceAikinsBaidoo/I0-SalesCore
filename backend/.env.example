# Local backend (run with: ./mvnw spring-boot:run)
# Copy to backend/.env and use a tool that loads env vars, or export manually.

SPRING_PROFILES_ACTIVE=dev

DATASOURCE_URL=jdbc:postgresql://localhost:5432/io_salescore
DATASOURCE_USERNAME=postgres
DATASOURCE_PASSWORD=your-postgres-password

# Dev default exists in application.yml if unset. Set explicitly in shared/staging/prod.
# APP_JWT_SECRET=

# Optional first-admin bootstrap (only when no ADMIN user exists).
# APP_BOOTSTRAP_TOKEN=

# Comma-separated origins for browser clients (Vite default: http://localhost:5173).
# APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
