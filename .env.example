# Copy to .env in this folder (io-salescore) for docker-compose.
# Never commit .env.

POSTGRES_DB=io_salescore
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# JWT signing secret (HS256) — use a long random string (32+ characters).
APP_JWT_SECRET=replace-with-long-random-secret-at-least-32-chars

# Optional: allow POST /api/v1/auth/bootstrap when no ADMIN exists yet.
# Leave empty to disable. Seeded DB from Flyway already has admin — see docs/MVP_CHECKLIST.md.
APP_BOOTSTRAP_TOKEN=

# Browser origins for CORS (comma-separated). For docker-compose, default http://localhost matches web on port 80.
APP_CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# Paystack server-side verification for online payments (CARD/MOBILE_MONEY).
# Leave verification enabled in production.
APP_PAYSTACK_SECRET_KEY=
APP_PAYSTACK_VERIFICATION_ENABLED=true
APP_PAYSTACK_EXPECTED_CURRENCY=GHS

# Ports (optional)
API_PORT=8080
WEB_PORT=80
